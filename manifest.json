{
  "manifest_version": 3,
  "name": "Sales Tax Price Calculator",
  "version": "1.0.3",
  "description": "Estimate sales tax on selected prices while shopping online. Not for tax filing or tax returns.",
  "homepage_url": "https://github.com/kr-ajay-0/sales-tax-price-calculator",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Sales Tax Price Calculator",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/content.js"
      ]
    }
  ]
}
